// View{{ $n }} iterates entities that have components {{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}, yielding typed slices per chunk.
type View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }} any{{ if lt $i $n }}, {{ end }}{{ end }}] struct {
    *query.View
}

// NewView{{ $n }} creates a View for entities that have {{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}, filtered by opts.
func NewView{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }} any{{ if lt $i $n }}, {{ end }}{{ end }}](
    ecs *ECS,
    opts ...BlueprintOpt,
) *View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}] {
    cc := &ecs.registry.CompCatalog
    var s comp.Spec{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}]
    s.Init(cc, opts...)

    return &View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}]{View: ecs.registry.AddView(&s.Blueprint)}
}

// All returns an iterator over matched entities, yielded in contiguous chunks.
//
// Example:
//
//	for chunk := range view.All() {
//		for i := range chunk.Entity {
//			_ = chunk.Comp1[i]
//		}
//	}
func (v *View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}]) All() iter.Seq[struct {
	Entity []EntityID
	{{- range $i := (seq 1 $n) }}
	Comp{{ $i }} []T{{ $i }}
	{{- end }}
}] {
	return func(yield func(
		struct {
			Entity []EntityID
			{{- range $i := (seq 1 $n) }}
			Comp{{ $i }} []T{{ $i }}
			{{- end }}
		},
	) bool) {
		for _, bt := range v.BakedTables {
			for i := range bt.Table.Chunks {
				chunk := &bt.Table.Chunks[i]
				count := chunk.Len
				if count == 0 {
					continue
				}
				base := chunk.Ptr
				if !yield(
					struct {
						Entity []EntityID
						{{- range $i := (seq 1 $n) }}
						Comp{{ $i }} []T{{ $i }}
						{{- end }}
					}{
						Entity: unsafe.Slice((*EntityID)(base), count),
						{{- range $i := (seq 1 $n) }}{{ $idx := sub $i 1 }}
						Comp{{ $i }}: unsafe.Slice((*T{{ $i }})(unsafe.Add(base, bt.CompOffsets[{{ $idx }}])), count),
						{{- end }}
					}) {
					return
				}
			}
		}
	}
}

// Filter yields the subset of selected entities that match the View's filter.
func (v *View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}]) Filter(selected []EntityID) iter.Seq2[int, struct {
	Entity EntityID
	{{- range $i := (seq 1 $n) }}
	Comp{{ $i }}  *T{{ $i }}
	{{- end }}
}] {
	return func(yield func(int, struct {
		Entity EntityID
		{{- range $i := (seq 1 $n) }}
		Comp{{ $i }}  *T{{ $i }}
		{{- end }}
	}) bool) {
		entityIndex := v.EntityIndex

		var lastArchID arch.ID = arch.NullID
		var bt *query.BakedTable
		for i, e := range selected {
			link, ok := entityIndex.Get(e)
			if !ok {
				continue
			}
			if link.ArchId != lastArchID {
				bt = v.Get(link.ArchId)
				lastArchID = link.ArchId
			}
			if bt == nil {
				continue
			}
			physPage := &bt.Table.Chunks[link.Pos.ChunkIdx]
			slot := uintptr(link.Pos.ChunkSlot)
			{{- range $i := (seq 1 $n) }}{{ $idx := sub $i 1 }}
			c{{ $idx }}Ptr := unsafe.Add(physPage.Ptr, bt.CompOffsets[{{ $idx }}]+(slot*bt.CompSizes[{{ $idx }}]))
			{{- end }}
			if !yield(i, struct {
				Entity EntityID
				{{- range $i := (seq 1 $n) }}
				Comp{{ $i }}  *T{{ $i }}
				{{- end }}
			}{
				Entity: e,
				{{- range $i := (seq 1 $n) }}{{ $idx := sub $i 1 }}
				Comp{{ $i }}: (*T{{ $i }})(c{{ $idx }}Ptr),
				{{- end }}
			}) {
				return
			}
		}
	}
}
