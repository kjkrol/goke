// --------------- View{{ $n }} ---------------

type View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }} any{{ if lt $i $n }}, {{ end }}{{ end }}] struct {
    *core.View
}

func NewView{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }} any{{ if lt $i $n }}, {{ end }}{{ end }}](
    ecs *ECS,
    opts ...BlueprintOption,
) *View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}] {
    registry := ecs.registry
    blueprint := core.NewBlueprint(registry)
    componentsRegistry := &registry.ComponentsRegistry

    mustAdd := func(info core.ComponentInfo) {
        if err := blueprint.WithComp(info); err != nil {
            panic(fmt.Sprintf("goke: view{{ $n }} init failed: %v", err))
        }
    }

    {{- range $i := (seq 1 $n) }}
    info{{ $i }} := componentsRegistry.GetOrRegister(reflect.TypeFor[T{{ $i }}]())
    {{- end }}

    {{- range $i := (seq 1 $n) }}
    mustAdd(info{{ $i }})
    {{- end }}

    for _, opt := range opts {
        if err := opt(blueprint); err != nil {
            panic(fmt.Sprintf("goke: view{{ $n }} option failed: %v", err))
        }
    }

    layout := []core.ComponentInfo{
        {{ range $i := (seq 1 $n) }}info{{ $i }}, {{end}}
    }

    view := core.NewView(blueprint, layout, registry)
    return &View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}]{View: view}
}

func (v *View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}]) All() iter.Seq[struct {
	Entity []Entity
	{{- range $i := (seq 1 $n) }}
	Comp{{ $i }} []T{{ $i }}
	{{- end }}
}] {
	return func(yield func(
		struct {
			Entity []Entity
			{{- range $i := (seq 1 $n) }}
			Comp{{ $i }} []T{{ $i }}
			{{- end }}
		},
	) bool) {
		for _, ma := range v.Baked {
			for _, page := range ma.Arch.Memory.Pages {
				count := page.Len
				if count == 0 {
					continue
				}
				base := page.Ptr
				if !yield(
					struct {
						Entity []Entity
						{{- range $i := (seq 1 $n) }}
						Comp{{ $i }} []T{{ $i }}
						{{- end }}
					}{
						Entity: unsafe.Slice((*Entity)(unsafe.Add(base, ma.EntityPageOffset)), count),
						{{- range $i := (seq 1 $n) }}{{ $idx := sub $i 1 }}
						Comp{{ $i }}: unsafe.Slice((*T{{ $i }})(unsafe.Add(base, ma.CompOffsets[{{ $idx }}])), count),
						{{- end }}
					}) {
					return
				}
			}
		}
	}
}

func (v *View{{ $n }}[{{ range $i := (seq 1 $n) }}T{{ $i }}{{ if lt $i $n }}, {{ end }}{{ end }}]) Filter(selected []Entity) iter.Seq[struct {
	Entity Entity
	{{- range $i := (seq 1 $n) }}
	Comp{{ $i }}  *T{{ $i }}
	{{- end }}
}] {
	return func(yield func(struct {
		Entity Entity
		{{- range $i := (seq 1 $n) }}
		Comp{{ $i }}  *T{{ $i }}
		{{- end }}
	}) bool) {
		store := &v.Reg.ArchetypeRegistry.EntityLinkStore

		var lastArchID core.ArchetypeId = core.NullArchetypeId
		var ma *core.MatchedArch
		for _, e := range selected {
			link, ok := store.Get(e)
			if !ok {
				continue
			}
			if link.ArchId != lastArchID {
				ma = v.GetMatchedArch(link.ArchId)
				lastArchID = link.ArchId
			}
			if ma == nil {
				continue
			}
			physPage := ma.Arch.Memory.Pages[link.PageIdx]
			row := uintptr(link.PageRow)
			{{- range $i := (seq 1 $n) }}{{ $idx := sub $i 1 }}
			c{{ $idx }}Ptr := unsafe.Add(physPage.Ptr, ma.CompOffsets[{{ $idx }}]+(row*ma.CompSizes[{{ $idx }}]))
			{{- end }}
			if !yield(struct {
				Entity Entity
				{{- range $i := (seq 1 $n) }}
				Comp{{ $i }}  *T{{ $i }}
				{{- end }}
			}{
				Entity: e,
				{{- range $i := (seq 1 $n) }}{{ $idx := sub $i 1 }}
				Comp{{ $i }}: (*T{{ $i }})(c{{ $idx }}Ptr),
				{{- end }}
			}) {
				return
			}
		}
	}
}
